# Copy to .env and fill in. Everything is optional unless noted.

PORT=8080
HOST=0.0.0.0

# SQLite file (a mounted volume inside the container)
DATABASE_PATH=./data/selfparcel.sqlite

# Scheduler timing, in minutes
POLL_INTERVAL_MINUTES=30
MIN_REFRESH_MINUTES=10

# UPS (free API). Create an app at https://developer.ups.com
UPS_CLIENT_ID=
UPS_CLIENT_SECRET=
UPS_ENV=production

# FedEx (free API). Create a project at https://developer.fedex.com
FEDEX_CLIENT_ID=
FEDEX_CLIENT_SECRET=
FEDEX_ENV=production

# USPS and SpeedPAK need no keys (they scrape the public tracking page).
# Set false to disable the Playwright fallback (HTTP only, fails more often).
SCRAPER_BROWSER_FALLBACK=true

# Auth mode: none (open), local (username/password), or oidc (SSO).
# Legacy AUTH_ENABLED=true still works and maps to oidc.
AUTH_MODE=none

# Discovery base URL (without /.well-known/openid-configuration)
OIDC_ISSUER=
OIDC_CLIENT_ID=
OIDC_CLIENT_SECRET=

# Signs session cookies. Required for local and oidc. openssl rand -hex 32
SESSION_SECRET=

# Callback URL registered with your provider. Blank = derived from the request
# (honours X-Forwarded-* behind a proxy), e.g. https://parcels.example.com/auth/callback
OIDC_REDIRECT_URI=

# Space-separated scopes; openid is required
OIDC_SCOPES=openid profile email

# Where to send the user after logout (defaults to the home page)
OIDC_POST_LOGOUT_REDIRECT_URI=

# Comma-separated allow-lists. If both empty, any user your provider authenticates
# is accepted. Use these to lock it down to your own accounts.
OIDC_ALLOWED_EMAILS=
OIDC_ALLOWED_DOMAINS=

# Session lifetime in hours (168 = 7 days)
SESSION_TTL_HOURS=168

# Allow a plain-HTTP issuer. Local dev only.
OIDC_ALLOW_INSECURE=false

# Public URL of this app, used for notification links
APP_BASE_URL=

# When to notify: status_change | every_event | delivered_exceptions
# (also changeable in the UI)
NOTIFY_TRIGGER=status_change

# Notify on the first successful fetch too (off by default, avoids a burst when
# you add packages that already shipped)
NOTIFY_ON_FIRST_FETCH=false

# Channels below are optional. Set the ones you want; they all fire together.

# ntfy: full topic URL. Token only needed for protected topics.
NTFY_URL=
NTFY_TOKEN=

# Pushover
PUSHOVER_TOKEN=
PUSHOVER_USER=

# Gotify: base server URL + an app token
GOTIFY_URL=
GOTIFY_TOKEN=

# Email (SMTP)
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM=
SMTP_TO=

# Generic webhook. WEBHOOK_FORMAT: json | discord | slack
WEBHOOK_URL=
WEBHOOK_FORMAT=json

# Apprise bridge: point at a self-hosted Apprise API /notify endpoint and list
# the service URLs to fan out to.
APPRISE_API_URL=
APPRISE_URLS=

# Browser push (Web Push). Generate keys with: npm run gen:vapid
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:you@example.com
