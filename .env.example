# Copy to .env and fill in. Everything is optional unless noted.

# Container timezone, e.g. America/New_York
TZ=UTC

PORT=8080
HOST=0.0.0.0

# SQLite file (a mounted volume inside the container)
DATABASE_PATH=./data/selfparcel.sqlite

# Scheduler timing, in minutes
POLL_INTERVAL_MINUTES=30
MIN_REFRESH_MINUTES=10

# Every carrier scrapes its public tracking page; no API keys needed (UPS/FedEx
# can optionally use their official API via per-user keys set in the app).
# Set false to disable the Playwright fallback (HTTP only, fails more often).
SCRAPER_BROWSER_FALLBACK=true

# The scraper is stealth-hardened to get past bot protection (USPS/UPS use
# Akamai). For the toughest cases, point at a real external Chrome over CDP
# (e.g. a browserless container) - this evades detection best:
# BROWSER_CDP_URL=ws://chrome:9222
# Or launch a real Chrome binary instead of the bundled chromium:
# BROWSER_EXECUTABLE_PATH=
# Run headful (needs a display / xvfb), harder to fingerprint than headless:
# BROWSER_HEADFUL=false

# Auth mode: none (open), local (username/password), or oidc (SSO).
# Legacy AUTH_ENABLED=true still works and maps to oidc.
AUTH_MODE=none

# Discovery base URL (without /.well-known/openid-configuration)
OIDC_ISSUER=
OIDC_CLIENT_ID=
OIDC_CLIENT_SECRET=

# Signs session cookies. Required for local and oidc. openssl rand -hex 32
SESSION_SECRET=

# Callback URL registered with your provider. Blank = derived from the request
# (honours X-Forwarded-* behind a proxy), e.g. https://parcels.example.com/auth/callback
OIDC_REDIRECT_URI=

# Space-separated scopes; openid is required
OIDC_SCOPES=openid profile email

# Where to send the user after logout (defaults to the home page)
OIDC_POST_LOGOUT_REDIRECT_URI=

# Comma-separated allow-lists. If both empty, any user your provider authenticates
# is accepted. Use these to lock it down to your own accounts.
OIDC_ALLOWED_EMAILS=
OIDC_ALLOWED_DOMAINS=

# Session lifetime in hours (168 = 7 days)
SESSION_TTL_HOURS=168

# Package sharing: when false (default), the share picker only suggests people
# you've shared with before — to reach anyone else you type their full email.
# Set true to suggest any user account (easier, but reveals who has an account).
EASY_DISCOVERABILITY=false

# Allow a plain-HTTP issuer. Local dev only.
OIDC_ALLOW_INSECURE=false

# Public URL of this app, used for notification links
APP_BASE_URL=

# When to notify: status_change | every_event | delivered_exceptions
# (also changeable in the UI)
NOTIFY_TRIGGER=status_change

# Notify on the first successful fetch too (off by default, avoids a burst when
# you add packages that already shipped)
NOTIFY_ON_FIRST_FETCH=false

# Notifications are configured entirely per-user in the app: each user adds
# their own channels (ntfy, Pushover, Gotify, webhook, email, Apprise) from a
# dropdown, including their own Apprise server. The ONLY notification setting
# that lives here is the SMTP relay below (email needs a server to send from).

# SMTP relay for email notifications. Each user adds their own recipient address
# in the UI; here you just configure the sender/relay. Leave blank to disable the
# email channel (the app then hides it as unavailable).
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM=

# Browser push (Web Push). OPTIONAL: the app auto-generates a VAPID keypair on
# first launch and persists it in the database, so browser push works with no
# setup. Only set these to pin a specific keypair (e.g. across multiple
# instances). Generate one with: npm run gen:vapid
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:you@example.com
