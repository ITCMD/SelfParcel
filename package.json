{
  "name": "selfparcel",
  "version": "0.1.0",
  "description": "Self-hosted US package tracking (UPS, USPS, FedEx, SpeedPAK)",
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc -p tsconfig.json && node scripts/copy-web.mjs",
    "start": "node dist/index.js",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "gen:vapid": "tsx scripts/gen-vapid.ts",
    "gen:icons": "node scripts/gen-icons.mjs",
    "postinstall": "playwright install chromium || true"
  },
  "dependencies": {
    "@fastify/cookie": "^9.4.0",
    "@fastify/static": "^7.0.4",
    "better-sqlite3": "^11.3.0",
    "cheerio": "^1.0.0",
    "fastify": "^4.28.1",
    "nodemailer": "^6.10.1",
    "openid-client": "^6.8.4",
    "playwright": "1.61.0",
    "playwright-extra": "^4.3.6",
    "puppeteer-extra-plugin-stealth": "^2.11.2",
    "undici": "^6.19.8",
    "web-push": "^3.6.7"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.11",
    "@types/node": "^22.5.5",
    "@types/nodemailer": "^6.4.24",
    "@types/web-push": "^3.6.4",
    "tsx": "^4.19.1",
    "typescript": "^5.6.2"
  }
}
